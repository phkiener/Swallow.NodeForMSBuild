<Project>
  <!-- Entry-point mapping -->
  <Target Name="_FrontendRestore" BeforeTargets="restore" DependsOnTargets="_InstallDependencies" />
  <Target Name="_FrontendBuild" BeforeTargets="PrepareForBuild" DependsOnTargets="_RunBuildScript" />
  <Target Name="_FrontendResolveStaticWebAssets" DependsOnTargets="_IncludeFrontendBuildAssets" />
  <Target Name="_FrontendClean" BeforeTargets="Clean" DependsOnTargets="_RemoveInstalledPackages;_CleanFrontendOutputs" />

  <!--
    Define the various item groups for later use. We want to make sure that none of our items is
    present in Content, otherwise it would be shipped directly as-is.
   -->
  <ItemGroup>
    <FrontendConfig Include="$(PackageJsonPath)package.json" />
    <FrontendConfig Include="$(PackageJsonPath)package-lock.json" />
    <FrontendBuild Include="@(FrontendCompilePatterns->'$(MSBuildProjectDirectory)**/%(Identity)')" Exclude="$(PackageJsonPath)node_modules/**/*;$(FrontendCompileExcludes)" />

    <Content Remove="@(FrontendConfig)" />
    <Content Remove="@(FrontendBuild)" />
    <Content Remove="$(PackageJsonPath)node_modules/**/*" />

    <None Include="@(FrontendConfig)" />
    <None Include="@(FrontendBuild)" />
  </ItemGroup>

  <!-- General setup; ensure that everything works. -->
  <Target Name="_SetupFrontendBuild">
    <ItemGroup>
      <_DependencyInstallStamp Include="$(BaseIntermediateOutputPath)npm-install.stamp" />
      <_FrontendBuildStamp Include="$(IntermediateOutputPath)npm-build.stamp" />

      <_FrontendInputs Include="@(FrontendBuild)" />
      <_FrontendInputs Include="@(FrontendConfig)" />
      <_FrontendInputs Include="@(FrontendDependencies)" />
      <_FrontendTarget Include="$(IntermediateOutputPath)dist/**/*" />
    </ItemGroup>
  </Target>

  <!-- Restore -->
  <Target Name="_RemoveInstalledPackages" DependsOnTargets="_SetupFrontendBuild" Condition="$(RestoreForce) == 'true'">
    <RemoveDir Directories="$(PackageJsonPath)node_modules/" />
    <Delete Files="@(_DependencyInstallStamp)" />
  </Target>

  <Target Name="_InstallDependencies" DependsOnTargets="_SetupFrontendBuild" Inputs="@(FrontendConfig)" Outputs="@(_DependencyInstallStamp)">
    <Exec Command="$(NpmToolPath) install" EchoOff="true" WorkingDirectory="$(PackageJsonPath)" />
    <WriteLinesToFile File="@(_DependencyInstallStamp)" Overwrite="true" Lines="$([System.DateTime]::Now.ToString('yyyy.MM.dd HH:mm:ss'))" />
  </Target>

  <!-- Build -->
  <Target Name="_RunBuildScript" DependsOnTargets="_InstallDependencies" Inputs="@(_FrontendInputs)" Outputs="@(_FrontendBuildStamp)" >
    <MakeDir Directories="$(IntermediateOutputPath)dist/" />

    <Exec Command="$(NpmToolPath) run --if-present $(NpmBuildTarget)"
          EnvironmentVariables="OUT_DIR=$(IntermediateOutputPath)dist/"
          EchoOff="true"
          WorkingDirectory="$(PackageJsonPath)" />

    <WriteLinesToFile File="@(_FrontendBuildStamp)" Overwrite="true" Lines="$([System.DateTime]::Now.ToString('yyyy.MM.dd HH:mm:ss'))" />
  </Target>

  <!-- StaticWebAssets -->
  <Target Name="_IncludeFrontendBuildAssets" DependsOnTargets="_FrontendBuild">

    <!-- TODO: What do ContentRrot and BasePath do? -->
    <DefineStaticWebAssets
      CandidateAssets="@(_FrontendTarget->Distinct())"
      FingerprintCandidates="$(StaticWebAssetsFingerprintContent)"
      FingerprintPatterns="@(StaticWebAssetFingerprintPattern)"
      RelativePathPattern="$(IntermediateOutputPath)dist/**/*"
      SourceType="Discovered"
      SourceId="$(PackageId)"
      ContentRoot="$(MSBuildProjectDirectory)"
      BasePath="$(StaticWebAssetBasePath)"
      AssetMergeSource="$(StaticWebAssetMergeTarget)"
      CacheManifestPath="$(_ResolveJSModuleStaticWebAssetsRazorCachePath)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_CurrentProjectStaticWebAsset" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints
      CandidateAssets="@(_CurrentProjectStaticWebAsset)"
      ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>

    <ItemGroup>
      <!-- TODO: What's going on here? -->
      <StaticWebAssetDiscoveryPattern Include="$(PackageId)\wwwroot" Condition="Exists('$(MSBuildProjectDirectory)\wwwroot')">
        <Source>$(PackageId)</Source>
        <BasePath>$(StaticWebAssetBasePath)</BasePath>
        <ContentRoot>$(MSBuildProjectDirectory)\wwwroot\</ContentRoot>
        <Pattern>**</Pattern>
      </StaticWebAssetDiscoveryPattern>

      <Content Remove="@(StaticWebAsset)" />
    </ItemGroup>
  </Target>

  <!-- Clean-->
  <Target Name="_CleanFrontendOutputs" DependsOnTargets="_SetupFrontendBuild">
    <Exec Command="$(NpmToolPath) run --if-present $(NpmCleanTarget)"
          EnvironmentVariables="OUT_DIR=$(IntermediateOutputPath)dist/"
          EchoOff="true"
          WorkingDirectory="$(PackageJsonPath)" />

    <RemoveDir Directories="$(IntermediateOutputPath)dist/" />
    <Delete Files="@(_FrontendBuildStamp)" />
  </Target>

</Project>
