<Project>

  <Target Name="_FrontendRestore" BeforeTargets="restore" DependsOnTargets="_InstallDependencies" />
  <Target Name="_FrontendBuild" BeforeTargets="PrepareForBuild" DependsOnTargets="_RunBuildScript" />
  <Target Name="_FrontendResolveStaticWebAssets" DependsOnTargets="_IncludeFrontendBuildAssets" />
  <Target Name="_FrontendClean" BeforeTargets="Clean" DependsOnTargets="_RemoveInstalledPackages;_CleanFrontendOutputs" />

  <PropertyGroup>
    <FrontendRootPath Condition="$(FrontendRootPath) == ''">$(MSBuildProjectDirectory)/</FrontendRootPath>
    <FrontendPackagePath>$(FrontendRootPath)node_modules/</FrontendPackagePath>

    <BuildToolPath Condition="$(BuildToolPath) == ''">npm</BuildToolPath>
    <BuildScriptName Condition="$(BuildScriptName) == ''">build</BuildScriptName>
    <CleanScriptName Condition="$(CleanScriptName) == ''">clean</CleanScriptName>
  </PropertyGroup>

  <ItemGroup>
    <FrontendConfig Include="$(FrontendRootPath)package.json" />
    <FrontendConfig Include="$(FrontendRootPath)package-lock.json" />
    <FrontendBuild Include="@(FrontendCompilePatterns->'$(MSBuildProjectDirectory)**/%(Identity)')" Exclude="$(FrontendPackagePath)**/*;$(FrontendCompileExcludes)" />

    <Content Remove="@(FrontendConfig)" />
    <Content Remove="@(FrontendBuild)" />
    <Content Remove="$(FrontendPackagePath)**/*" />

    <None Include="@(FrontendConfig)" />
    <None Include="@(FrontendBuild)" />
  </ItemGroup>

  <!-- SETUP -->

  <Target Name="_SetupFrontendBuild">
    <PropertyGroup>
      <FrontendOutputPath Condition="$(FrontendOutputPath) == ''">$(IntermediateOutputPath)dist/</FrontendOutputPath>
    </PropertyGroup>

    <ItemGroup>
      <_DependencyInstallStamp Include="$(BaseIntermediateOutputPath)npm-install.stamp" />
      <_FrontendBuildStamp Include="$(IntermediateOutputPath)npm-build.stamp" />

      <_FrontendBuildInput Include="@(FrontendConfig)" />
      <_FrontendBuildInput Include="@(FrontendBuild)" />
    </ItemGroup>
  </Target>

  <!-- RESTORE -->

  <Target Name="_RemoveInstalledPackages" DependsOnTargets="_SetupFrontendBuild" BeforeTargets="_InstallDependencies" Condition="$(RestoreForce) == 'true'">
    <RemoveDir Directories="$(FrontendPackagePath)" />
    <Delete Files="@(_DependencyInstallStamp)" />
  </Target>

  <Target Name="_InstallDependencies" DependsOnTargets="_SetupFrontendBuild" Inputs="@(FrontendConfig)" Outputs="@(_DependencyInstallStamp)">
    <Exec Command="$(BuildToolPath) install" EchoOff="true" WorkingDirectory="$(FrontendRootPath)" />
    <WriteLinesToFile File="@(_DependencyInstallStamp)" Lines="$([System.DateTime]::Now.ToBinary())" />
  </Target>

  <!-- BUILD -->

  <Target Name="_RunBuildScript" DependsOnTargets="_InstallDependencies" Inputs="@(_FrontendBuildInput)" Outputs="@(_FrontendBuildStamp)">
    <MakeDir Directories="$(FrontendOutputPath)" />

    <Exec Command="$(BuildToolPath) run --if-present $(BuildScriptName)"
          EnvironmentVariables="OUT_DIR=$(FrontendOutputPath)"
          EchoOff="true"
          WorkingDirectory="$(FrontendRootPath)" />

    <WriteLinesToFile File="@(_FrontendBuildStamp)" Lines="$([System.DateTime]::Now.ToBinary())" />
  </Target>

  <Target Name="_IncludeFrontendBuildAssets" DependsOnTargets="_FrontendBuild">
    <ItemGroup>
      <_FrontendOutput Include="$(FrontendOutputPath)**/*" />
    </ItemGroup>
    <DefineStaticWebAssets
      CandidateAssets="@(_FrontendOutput->Distinct())"
      RelativePathPattern="$(FrontendOutputPath)**/*"
      ContentRoot="$(FrontendOutputPath)"
      BasePath="$(StaticWebAssetBasePath)"
      SourceType="Computed"
      SourceId="$(PackageId)"
      AssetMergeSource="$(StaticWebAssetMergeTarget)"
    >
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_CurrentProjectStaticWebAsset" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints
      CandidateAssets="@(_CurrentProjectStaticWebAsset)"
      ExistingEndpoints="@(StaticWebAssetEndpoint)"
      ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>
  </Target>

  <!-- CLEAN -->

  <Target Name="_CleanFrontendOutputs" DependsOnTargets="_SetupFrontendBuild">
    <Exec Command="$(BuildToolPath) run --if-present $(CleanScriptName)"
          EnvironmentVariables="OUT_DIR=$(FrontendOutputPath)"
          EchoOff="true"
          WorkingDirectory="$(FrontendRootPath)" />

    <RemoveDir Directories="$(FrontendOutputPath)" />
    <Delete Files="@(_FrontendBuildStamp)" />
  </Target>

</Project>
